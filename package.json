{
    "name":  "dyslexia-support-skill",
    "version":  "1.2.0",
    "description":  "Multi-format distribution system for dyslexia cognitive accommodation across K-12, higher education, workplace, and adult contexts",
    "license":  "MIT",
    "author":  "Justice",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "build":  "tsx build.ts",
                    "build:claude-plugin":  "tsx build.ts --format claude-plugin",
                    "build:mcp":  "tsx build.ts --format mcp \u0026\u0026 cd dist/mcp-server \u0026\u0026 npm install",
                    "build:openai":  "tsx build.ts --format openai",
                    "build:n8n":  "tsx build.ts --format n8n",
                    "build:prompts":  "tsx build.ts --format prompts",
                    "clean":  "rm -rf dist",
                    "dev":  "tsx build.ts --watch",
                    "lint":  "eslint source/ build.ts",
                    "test":  "tsx test-build.ts",
                    "audit":  "npm audit --audit-level=high",
                    "sbom":  "npx @cyclonedx/cyclonedx-npm --output-file sbom.cdx.json --output-reproducible",
                    "prepack":  "npm run build",
                    "build:cli":  "tsx build.ts --format cli"
                },
    "dependencies":  {

                     },
    "devDependencies":  {
                            "@types/node":  "^20.0.0",
                            "@types/js-yaml":  "^4.0.5",
                            "glob":  "^10.0.0",
                            "js-yaml":  "^4.1.0",
                            "typescript":  "^5.0.0",
                            "tsx":  "^4.0.0"
                        },
    "engines":  {
                    "node":  "\u003e=18.0.0"
                },
    "keywords":  [
                     "dyslexia",
                     "accessibility",
                     "education",
                     "iep",
                     "remediation",
                     "compliance",
                     "standards",
                     "mcp",
                     "openai",
                     "n8n",
                     "claude"
                 ]
}
